# Database Entity-Relationship Diagram

This document contains the Entity-Relationship Diagram (ERD) mapping the relationships between the tables in your Gold ERP system.

```mermaid
erDiagram
    %% Master Tables
    dealers {
        int id PK
        varchar code
        varchar name
        boolean is_active
    }
    
    workers {
        int id PK
        varchar code
        varchar name
        boolean is_active
    }
    
    product_types {
        int id PK
        varchar code
        varchar name
        boolean is_active
    }
    
    design_types {
        int id PK
        varchar code
        varchar name
        int product_type_id FK
    }
    
    alloy_types {
        int id PK
        varchar code
        varchar name
    }

    %% Daybook & Ledger
    daybook_entries {
        int serial_no PK
        date entry_date
        varchar type
    }
    
    ledger_accounts {
        int id PK
        varchar account_name
        varchar account_type
    }
    
    ledger_entries {
        int id PK
        int account_id FK
        int daybook_sno FK
        float debit_amount
        float credit_amount
    }
    
    v_account_entries {
        int id PK
        int worker_id FK
        int daybook_sno FK
        float balance_g
    }

    %% Gold Box
    gold_box_stock {
        int id PK
        int daybook_sno FK
        float weight_g
    }
    
    gold_box_issues {
        int id PK
        int worker_id FK
        int daybook_sno FK
        float weight_g
    }

    %% Core Inventory
    gold_receipts {
        int id PK
        int dealer_id FK
        int daybook_sno FK
        float weight_g
    }
    
    chain_stock {
        int id PK
        int design_type_id FK
        int product_type_id FK
        float weight_g
    }
    
    finished_stock {
        int id PK
        int kambi_batch_id FK
        int product_type_id FK
        int design_type_id FK
        float weight_balance_g
    }

    tag_stock {
        int id PK
        int product_type_id FK
        int design_type_id FK
        float tagged_weight_g
    }

    %% Manufacturing Processes
    melt_batches {
        int id PK
        int worker_id FK
        int product_type_id FK
        float final_916_g
    }
    
    melt_batch_inputs {
        int id PK
        int melt_batch_id FK
        int receipt_id FK
        float weight_used_g
    }
    
    melt_batch_alloys {
        int id PK
        int melt_batch_id FK
        int alloy_type_id FK
        float weight_g
    }
    
    kambi_batches {
        int id PK
        int melt_batch_id FK
        int worker_id FK
        int product_type_id FK
        float weight_out_g
    }
    
    chain_batches {
        int id PK
        int kambi_batch_id FK
        int worker_id FK
        int design_type_id FK
        int product_type_id FK
        float weight_out_g
    }
    
    solder_returns {
        int id PK
        int product_type_id FK
        int sent_to_melt_batch_id FK
        float weight_g
    }

